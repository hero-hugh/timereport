# --- Databases ---
# Auth/central DB (shared across users). Path is relative to apps/api when running
# from that directory. In prod (Docker), this is typically file:/data/auth.db.
AUTH_DATABASE_URL="file:./data/auth.db"

# Directory where per-user SQLite files (<userId>.db) are created at runtime.
DATABASE_DIR="./data"

# Placeholder for Prisma client generation only — overridden per user at runtime.
USER_DATABASE_URL="file:./data/placeholder.db"

# --- Auth / JWT ---
# Generate with: openssl rand -base64 48
# Must be set, min 32 chars, and MUST differ from JWT_REFRESH_SECRET.
JWT_SECRET="REPLACE_ME_OPENSSL_RAND_BASE64_48"

# Generate with: openssl rand -base64 48
# Must be different from JWT_SECRET.
JWT_REFRESH_SECRET="REPLACE_ME_OPENSSL_RAND_BASE64_48_DIFFERENT"

# --- At-rest encryption ---
# 32 bytes base64. Generate with: openssl rand -base64 32
# Used to envelope-encrypt stored third-party tokens (e.g. Box API).
# Rotating this key invalidates all stored encrypted values — plan migrations carefully.
TOKEN_ENCRYPTION_KEY="REPLACE_ME_OPENSSL_RAND_BASE64_32"

# --- Frontend / CORS ---
# Must be https:// in production. Startup assertion fails otherwise.
FRONTEND_URL="http://localhost:5173"

# --- Email (OTP delivery) ---
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="Tidrapport <noreply@your-domain.com>"

# --- Optional: dev/E2E only ---
# NEVER set in production — forces OTP to a fixed value, turning login into a no-op.
# The server will refuse to boot if this is set with NODE_ENV=production.
# E2E_TEST_OTP="000000"
